# -----------------------------------------------------------------------
# Copy this file to .env and fill in real values before running.
# Generate SECRET_KEY with:  openssl rand -hex 32
# -----------------------------------------------------------------------

# PostgreSQL
POSTGRES_PASSWORD=supersecret_change_me

# FastAPI JWT
SECRET_KEY=change_this_to_a_random_64_character_hex_string
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Browser-reachable API URL (NOT the internal Docker service name)
VITE_API_URL=http://localhost:8000
